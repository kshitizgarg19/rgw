# RGW Sweets — environment template. Copy to .env and fill in.

# Postgres connection string (Neon / Supabase / Vercel Postgres).
# Use the DIRECT (non-pooled) URL for `prisma db push` & seed; pooled is fine at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign admin session JWTs. Use a long random string in prod.
JWT_SECRET="change-me-to-a-long-random-string"

# First Super Admin, created by `npm run db:seed`
ADMIN_EMAIL="admin@rgwsweets.in"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="RGW Super Admin"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Payment (ON HOLD) — PhonePe, enable in the next phase ──
# PHONEPE_MERCHANT_ID=""
# PHONEPE_SALT_KEY=""
# PHONEPE_SALT_INDEX="1"
# PHONEPE_ENV="UAT"
